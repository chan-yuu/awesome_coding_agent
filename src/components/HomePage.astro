---
import BrandWall from './BrandWall.astro';
import EditorialFeature from './EditorialFeature.astro';
import Infographics from './Infographics.astro';
import InteractiveLandscape from './InteractiveLandscape.astro';
import ToolCard from './ToolCard.astro';
import { copy, getFaviconUrl, tools } from '../data/catalog';
import type { Locale } from '../data/catalog';

const { locale } = Astro.props as { locale: Locale };

const content = copy[locale];
const openTools = tools.filter((tool) => tool.category === 'open');
const closedTools = tools.filter((tool) => tool.category === 'closed');
const topOpenStars = openTools[0]?.stars ?? '';
const totalTools = tools.length;
const openCount = openTools.length;
const closedCount = closedTools.length;
const toolsByName = new Map(tools.map((tool) => [tool.name, tool]));
const sectionNav = [
	{ id: 'lineup', label: content.sectionLabels.lineup },
	{ id: 'signal', label: content.sectionLabels.signal },
	{ id: 'brands', label: content.sectionLabels.brands },
	{ id: 'notes', label: content.sectionLabels.notes },
	{ id: 'filters', label: content.sectionLabels.filters },
	{ id: 'maps', label: content.sectionLabels.maps },
	{ id: 'open-source', label: content.sectionLabels.open },
	{ id: 'closed-source', label: content.sectionLabels.closed },
	{ id: 'pricing', label: content.sectionLabels.pricing },
	{ id: 'source', label: content.sectionLabels.source },
];
---

<div class="page-shell">
	<header class="hero">
		<nav class="topbar">
			<a class="brand" href="https://github.com/chan-yuu/awesome_coding_agent" target="_blank" rel="noreferrer">
				<span class="brand__dot"></span>
				Awesome Coding Agents
			</a>
			<a class="lang-switch" href={content.otherLangHref}>{content.otherLangLabel}</a>
		</nav>

		<div class="hero__content">
			<div class="hero__copy">
				<p class="eyebrow">{content.eyebrow}</p>
				<h1>{content.title}</h1>
				<p class="hero__subtitle">{content.subtitle}</p>
				<div class="hero__actions">
					<a class="button button--primary" href={content.ctaPrimaryHref} target="_blank" rel="noreferrer">
						{content.ctaPrimary}
					</a>
					<a class="button button--secondary" href={content.ctaSecondaryHref} target="_blank" rel="noreferrer">
						{content.ctaSecondary}
					</a>
				</div>
			</div>

			<div class="hero__panel">
				<p class="hero__panel-label">{content.snapshotTitle}</p>
				<p class="hero__panel-text">{content.snapshotText}</p>
				<div class="market-map">
					<div class="market-map__grid"></div>
					<div class="market-map__core">
						<span>{locale === 'en' ? 'Agent Era' : '代理时代'}</span>
					</div>
					{content.modes.map((mode, index) => (
						<div class={`market-map__node market-map__node--${index + 1}`}>{mode}</div>
					))}
				</div>
				<div class="signal-metrics">
					<div class="signal-metric">
						<span>{locale === 'en' ? 'Products tracked' : '已收录产品'}</span>
						<strong>{totalTools}</strong>
					</div>
					<div class="signal-metric">
						<span>{locale === 'en' ? 'Open-source leaders' : '开源重点'}</span>
						<strong>{openCount}</strong>
					</div>
					<div class="signal-metric">
						<span>{locale === 'en' ? 'Top open-source star signal' : '最高开源 star 信号'}</span>
						<strong>{topOpenStars}</strong>
					</div>
				</div>
				<div class="hero__grid">
					{content.highlights.map((item) => (
						<div class="snapshot-card">
							<h3>{item.title}</h3>
							<p>{item.text}</p>
						</div>
					))}
				</div>
			</div>
		</div>
	</header>

	<nav class="reader-dock" aria-label={content.directoryTitle} data-section-nav>
		{sectionNav.map((item, index) => (
			<a class={`reader-nav__link ${index === 0 ? 'is-active' : ''}`} href={`#${item.id}`} data-nav-link={`#${item.id}`}>
				{item.label}
			</a>
		))}
	</nav>

	<section class="reader-nav">
		<div class="reader-nav__intro">
			<p class="section__eyebrow">Guide</p>
			<h2>{content.directoryTitle}</h2>
			<p>{content.directoryText}</p>
		</div>
	</section>

	<main class="content">
		<section class="section lineup" id="lineup" data-observe-section>
			<div class="section__heading">
				<p class="section__eyebrow">Lineup</p>
				<h2>{content.lineupTitle}</h2>
				<p>{content.lineupText}</p>
			</div>
			<div class="lineup-grid">
				{tools.map((tool) => (
					<article class="lineup-card" style={`--brand:${tool.brandColor};`}>
						<div class="lineup-card__logo-shell">
							<img class="lineup-card__logo" src={getFaviconUrl(tool.brandUrl)} alt={`${tool.name} logo`} loading="lazy" />
						</div>
						<div class="lineup-card__body">
							<h3>{tool.name}</h3>
							<p>{tool.type[locale]}</p>
						</div>
						<span class={`lineup-card__tag lineup-card__tag--${tool.category}`}>
							{tool.category === 'open' ? (locale === 'en' ? 'Open' : '开源') : locale === 'en' ? 'Closed' : '闭源'}
						</span>
					</article>
				))}
			</div>
		</section>

		<section class="section signal-strip" id="signal" data-observe-section>
			<div class="section__heading section__heading--compact">
				<p class="section__eyebrow">Signal</p>
				<h2>{content.signalTitle}</h2>
				<p>{content.modeText}</p>
			</div>

			<div class="signal-strip__grid">
				<div class="signal-chart">
					<div class="signal-chart__header">
						<span>{locale === 'en' ? 'Market split' : '市场结构'}</span>
						<strong>{openCount} / {closedCount}</strong>
					</div>
					<div class="signal-chart__bars">
						<div class="signal-chart__bar signal-chart__bar--open" style={`--value:${(openCount / totalTools) * 100}%`}>
							<span>{locale === 'en' ? 'Open-source' : '开源'}</span>
						</div>
						<div class="signal-chart__bar signal-chart__bar--closed" style={`--value:${(closedCount / totalTools) * 100}%`}>
							<span>{locale === 'en' ? 'Closed-source' : '闭源'}</span>
						</div>
					</div>
				</div>

				{content.signalCards.map((card) => (
					<div class="signal-story">
						<h3>{card.title}</h3>
						<p>{card.text}</p>
					</div>
				))}
			</div>
		</section>

		<div id="brands" data-observe-section>
			<BrandWall locale={locale} title={content.brandWallTitle} text={content.brandWallText} />
		</div>

		<div id="notes" data-observe-section>
			<EditorialFeature
				locale={locale}
				title={content.editorialTitle}
				text={content.editorialText}
				quote={content.editorialQuote}
				cards={content.editorialCards}
				toolsByName={toolsByName}
			/>
		</div>

		<div id="filters" data-observe-section>
			<InteractiveLandscape
				locale={locale}
				copy={{
					title: content.filterTitle,
					text: content.filterText,
					axisXLow: content.axisXLow,
					axisXHigh: content.axisXHigh,
					axisYLow: content.axisYLow,
					axisYHigh: content.axisYHigh,
					axisXLabel: content.axisXLabel,
					axisYLabel: content.axisYLabel,
				}}
			/>
		</div>

		<div id="maps" data-observe-section>
			<Infographics
				locale={locale}
				copy={{
					matrixTitle: content.matrixTitle,
					matrixText: content.matrixText,
					mapTitle: content.mapTitle,
					mapText: content.mapText,
					atlasTitle: content.atlasTitle,
					atlasText: content.atlasText,
					axisXLow: content.axisXLow,
					axisXHigh: content.axisXHigh,
					axisYLow: content.axisYLow,
					axisYHigh: content.axisYHigh,
				}}
			/>
		</div>

		<section class="section" id="open-source" data-observe-section>
			<div class="section__heading">
				<p class="section__eyebrow">Open Source</p>
				<h2>{content.openTitle}</h2>
				<p>{content.openText}</p>
			</div>
			<div class="tool-grid">
				{openTools.map((tool) => <ToolCard locale={locale} tool={tool} labels={content.cardLabels} />)}
			</div>
		</section>

		<section class="section" id="closed-source" data-observe-section>
			<div class="section__heading">
				<p class="section__eyebrow">Closed Source</p>
				<h2>{content.closedTitle}</h2>
				<p>{content.closedText}</p>
			</div>
			<div class="tool-grid">
				{closedTools.map((tool) => <ToolCard locale={locale} tool={tool} labels={content.cardLabels} />)}
			</div>
		</section>

		<section class="section section--split" id="pricing" data-observe-section>
			<div class="split-card">
				<p class="section__eyebrow">Pricing</p>
				<h2>{content.pricingTitle}</h2>
				<p>{content.pricingText}</p>
				<ul class="bullet-list">
					{content.pricingPoints.map((point) => <li>{point}</li>)}
				</ul>
			</div>

			<div class="split-card">
				<p class="section__eyebrow">Quick Picks</p>
				<h2>{content.picksTitle}</h2>
				<ul class="bullet-list">
					{content.picks.map((pick) => <li>{pick}</li>)}
				</ul>
			</div>
		</section>

		<section class="section source-box" id="source" data-observe-section>
			<p class="section__eyebrow">Source</p>
			<h2>{content.sourceTitle}</h2>
			<p>{content.sourceText}</p>
			<div class="hero__actions">
				<a class="button button--primary" href={content.sourcePrimaryHref} target="_blank" rel="noreferrer">
					{content.sourcePrimary}
				</a>
				<a class="button button--secondary" href={content.sourceSecondaryHref} target="_blank" rel="noreferrer">
					{content.sourceSecondary}
				</a>
			</div>
		</section>
	</main>

	<footer class="footer">
		<p>{content.footer}</p>
	</footer>
</div>

<script is:inline>
	const navRoot = document.querySelector('[data-section-nav]');
	const navLinks = Array.from(document.querySelectorAll('[data-nav-link]'));
	const observedSections = Array.from(document.querySelectorAll('[data-observe-section]'));

	if (navRoot && navLinks.length && observedSections.length) {
		const activate = (id) => {
			navLinks.forEach((link) => {
				link.classList.toggle('is-active', link.getAttribute('href') === `#${id}`);
			});
		};

		const observer = new IntersectionObserver(
			(entries) => {
				const visible = entries
					.filter((entry) => entry.isIntersecting)
					.sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

				if (visible?.target?.id) {
					activate(visible.target.id);
				}
			},
			{
				rootMargin: '-20% 0px -55% 0px',
				threshold: [0.2, 0.35, 0.5],
			},
		);

		observedSections.forEach((section) => observer.observe(section));
	}
</script>
