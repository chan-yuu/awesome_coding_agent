---
import { getFaviconUrl, pricingLabel, surfaceLabel } from '../data/catalog';
import type { Locale, Tool } from '../data/catalog';

const { locale, tool, labels } = Astro.props as {
	locale: Locale;
	tool: Tool;
	labels: {
		highlight: string;
		pricing: string;
		bestFor: string;
	};
};
---

<article class="tool-card" style={`--brand:${tool.brandColor};`}>
	<div class="tool-card__top">
		<div class="tool-card__brand-block">
			<div class="tool-card__logo-shell">
				<img class="tool-card__logo" src={getFaviconUrl(tool.brandUrl)} alt={`${tool.name} logo`} loading="lazy" />
			</div>
			<div class="tool-card__name-row">
				<h3>{tool.name}</h3>
				{tool.stars && <span class="tool-card__stars">{tool.stars}</span>}
			</div>
			<p class="tool-card__type">{tool.type[locale]}</p>
			<div class="tool-card__chips">
				<span class="tool-card__chip">{tool.category === 'open' ? (locale === 'en' ? 'Open source' : '开源') : locale === 'en' ? 'Closed source' : '闭源'}</span>
				<span class="tool-card__chip">{surfaceLabel(tool.surfaceGroup, locale)}</span>
				<span class="tool-card__chip">{pricingLabel(tool.pricingModel, locale)}</span>
			</div>
		</div>
		<a class="tool-card__link" href={tool.href} target="_blank" rel="noreferrer">Open</a>
	</div>

	<dl class="tool-card__meta">
		<div>
			<dt>{labels.highlight}</dt>
			<dd>{tool.highlight[locale]}</dd>
		</div>
		<div>
			<dt>{labels.pricing}</dt>
			<dd>{tool.pricing[locale]}</dd>
		</div>
		<div>
			<dt>{labels.bestFor}</dt>
			<dd>{tool.bestFor[locale]}</dd>
		</div>
	</dl>
</article>
