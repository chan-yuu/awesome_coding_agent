---
import type { Locale, Tool } from '../data/catalog';

const { locale, tool, labels } = Astro.props as {
	locale: Locale;
	tool: Tool;
	labels: {
		highlight: string;
		pricing: string;
		bestFor: string;
	};
};
---

<article class="tool-card">
	<div class="tool-card__top">
		<div>
			<div class="tool-card__name-row">
				<h3>{tool.name}</h3>
				{tool.stars && <span class="tool-card__stars">{tool.stars}</span>}
			</div>
			<p class="tool-card__type">{tool.type[locale]}</p>
		</div>
		<a class="tool-card__link" href={tool.href} target="_blank" rel="noreferrer">Open</a>
	</div>

	<dl class="tool-card__meta">
		<div>
			<dt>{labels.highlight}</dt>
			<dd>{tool.highlight[locale]}</dd>
		</div>
		<div>
			<dt>{labels.pricing}</dt>
			<dd>{tool.pricing[locale]}</dd>
		</div>
		<div>
			<dt>{labels.bestFor}</dt>
			<dd>{tool.bestFor[locale]}</dd>
		</div>
	</dl>
</article>
